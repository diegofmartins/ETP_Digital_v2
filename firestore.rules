rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /test/connection {
      allow read: if true;
    }
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (user, master) - required
    //   - createdAt: timestamp
    //
    // Collection: etps
    // Document ID: {etpId}
    // Fields:
    //   - id: string
    //   - userId: string (required)
    //   - userEmail: string
    //   - title: string
    //   - status: string (draft, completed, deleted, active)
    //   - data: map (ETPData)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //   - deletedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default master has absolute authority
    function isDefaultMaster() {
      return isAuthenticated() && 
             request.auth.token.email.lower() == "diego.martins@cmc.pr.gov.br";
    }
    
    // Retrieve user document data
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Check if current user is master
    function isMaster() {
      return isAuthenticated() && (
        isDefaultMaster() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master'
        )
      );
    }
    
    // Check if current user is approved
    function isApproved() {
      return isAuthenticated() && (
        isDefaultMaster() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        )
      );
    }

    // Comprehensive validation for User document
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             data.role is string &&
             data.status is string;
    }

    // Validation for ETP documents
    function isValidETP(data) {
      return data.userId is string && 
             data.status is string &&
             data.data is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Users can see their own profile, Master can see all
      allow get: if isAuthenticated() && (isOwner(uid) || isMaster());
      
      // Allow users to check if their own email exists to prevent duplicates during login
      // Master can list everything
      allow list: if isMaster() || (
        isAuthenticated() && 
        request.query.limit <= 1 && 
        'email' in request.auth.token &&
        request.auth.token.email.lower() in request.query.filters.email
      );
      
      // New users register as pending/user, unless default master
      allow create: if isAuthenticated() && (
        (isOwner(uid) && isValidUser(request.resource.data) && (
          isDefaultMaster() || (request.resource.data.status == 'pending' && request.resource.data.role == 'user')
        )) ||
        isMaster()
      );
      
      // Only Master can change roles/status. Users can update their own data (like presence) 
      // but MUST not touch their role or status.
      allow update: if isAuthenticated() && (
        isMaster() || (
          isOwner(uid) && 
          isValidUser(request.resource.data) &&
          (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
          (!('status' in request.resource.data) || request.resource.data.status == resource.data.status)
        )
      );
      
      // Strict lockdown on deletions
      allow delete: if isMaster();
    }

    match /etps/{etpId} {
      // Only owner or Master can read
      // Using resource.data in list rule ensures users can ONLY list their own etps
      allow get, list: if isAuthenticated() && (isMaster() || resource.data.userId == request.auth.uid);
      
      // Only approved users can maintain ETPs
      allow create: if (isApproved() || isMaster()) && 
                    (request.resource.data.userId == request.auth.uid || isMaster()) &&
                    isValidETP(request.resource.data);
                    
      allow update: if (isApproved() || isMaster()) && 
                    (resource.data.userId == request.auth.uid || isMaster()) &&
                    isValidETP(request.resource.data) &&
                    (request.resource.data.userId == resource.data.userId || isMaster()); // Master can reassign
                    
      allow delete: if (isApproved() || isMaster()) && (resource.data.userId == request.auth.uid || isMaster());
    }
  }
}
