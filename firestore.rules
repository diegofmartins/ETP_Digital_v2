rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (user, master) - required
    //   - createdAt: timestamp
    //
    // Collection: etps
    // Document ID: {etpId}
    // Fields:
    //   - id: string
    //   - userId: string (required)
    //   - userEmail: string
    //   - title: string
    //   - status: string (draft, completed, deleted, active)
    //   - data: map (ETPData)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //   - deletedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDefaultMaster() {
      return isAuthenticated() && 
             request.auth.token.email == "diego.martins@cmc.pr.gov.br" && 
             request.auth.token.email_verified == true;
    }
    
    function isMaster() {
      return isDefaultMaster() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master'
      );
    }
    
    function isApproved() {
      return isDefaultMaster() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'master'] &&
             data.status in ['pending', 'approved', 'disabled'];
    }

    function isValidETP(data) {
      return data.keys().hasAll(['userId', 'data', 'status']) &&
             data.userId is string &&
             data.status in ['draft', 'completed', 'deleted', 'active'] &&
             data.data is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow get: if isAuthenticated() && (isOwner(uid) || isMaster());
      allow list: if isMaster();
      
      // New users start as pending, except for the default master email
      // Master can also create any user (useful for backup restoration)
      allow create: if isAuthenticated() && (
        (isOwner(uid) && isValidUser(request.resource.data) && (
          (request.resource.data.status == 'pending' && request.resource.data.role == 'user') ||
          isDefaultMaster()
        )) ||
        isMaster()
      );
      
      // Only Master can update status or roles
      allow update: if isAuthenticated() && 
                    (isMaster() || (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status));
      
      // Only Master can delete users
      allow delete: if isMaster();
    }

    match /etps/{etpId} {
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isMaster());
      allow list: if isAuthenticated() && (isMaster() || (request.query.filters.userId == request.auth.uid));
      
      allow create: if (isApproved() || isMaster()) && 
                    (request.resource.data.userId == request.auth.uid || isMaster());
      allow update: if (isApproved() || isMaster()) && 
                    (resource.data.userId == request.auth.uid || isMaster());
      allow delete: if (isApproved() || isMaster()) && (resource.data.userId == request.auth.uid || isMaster());
    }
  }
}
