rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDefaultMaster() {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() == "diego.martins@cmc.pr.gov.br";
    }

    function isMaster() {
      return isAuthenticated() && (
        isDefaultMaster() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master')
      );
    }

    function isApproved() {
      return isAuthenticated() && (
        isDefaultMaster() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved')
      );
    }

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isMaster());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (request.auth.uid == uid || isMaster());
      allow delete: if isAuthenticated() && (
        isMaster() || 
        (resource.data.email.lower() == request.auth.token.email.lower())
      );
    }

    match /etps/{etpId} {
      allow get, list: if isAuthenticated() && (isMaster() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isMaster());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isMaster());
    }

    match /config/system {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    match /backups/{backupId} {
      allow read, write: if isMaster();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
