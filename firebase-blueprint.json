{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "master"] },
        "status": { "type": "string", "enum": ["pending", "approved", "disabled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "ETPDraft": {
      "title": "ETP Draft",
      "description": "Draft of an ETP document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "in_progress", "completed", "deleted", "active"] },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "data", "status"]
    },
    "SystemConfig": {
      "title": "System Config",
      "description": "Global system configuration",
      "type": "object",
      "properties": {
        "chatWebhookUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/etps/{etpId}": {
      "schema": "ETPDraft",
      "description": "ETP drafts and documents"
    },
    "/config/system": {
      "schema": "SystemConfig",
      "description": "Global system settings"
    }
  }
}
